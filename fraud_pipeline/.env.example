# ── LLM Keys ──────────────────────────────────────────────────
LLM_MODE=HYBRID
GEMINI_API_KEY="your api key"
# GEMINI_API_KEY=another_key_here



# ── Model Selection (change here, no code changes needed) ─────
# Gemini: gemini-2.5-flash | gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash-lite
# Local LLM: llama3.2 | llama3.1 | mistral | phi3 | gemma2  (must: ollama pull <model>)
LOCAL_LLM_MODEL=llama3.2

# ── PostgreSQL (matches docker-compose) ───────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claimos_fraud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── Agent 1 Fraud Thresholds (tunable by business team — no code deploy needed) ──
# How many times a ROHINI ID can appear in claims within 90 days before HIGH_FREQUENCY fires
HOSPITAL_FREQ_THRESHOLD=5
# How many times a doctor registration number can appear in claims within 90 days
DOCTOR_FREQ_THRESHOLD=5
# How many days after death a FIR can be filed before FIR_DATE_ANOMALY fires
FIR_DATE_ANOMALY_DAYS=30
# ELA mean pixel-difference above which ELA_ANOMALY_DETECTED fires
ELA_ANOMALY_THRESHOLD=15.0
# How many days between PDF CreationDate and ModDate before PDF_MODIFICATION_ANOMALY fires
PDF_MOD_DATE_ANOMALY_DAYS=7
# OCR confidence below this triggers LOW_OCR flag
OCR_LOW_CONFIDENCE_THRESHOLD=0.55
# Nominee appears in how many claims before repeated_nominee signal fires in Agent 2
NOMINEE_FREQ_THRESHOLD=2
# Bank account appears in how many claims before repeated_bank_account signal fires
BANK_ACCOUNT_FREQ_THRESHOLD=2
