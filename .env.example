# ─────────────────────────────────────────────────────────────
# CLAIMOS AI — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                   # Fallback if Anthropic returns 503
OPENAI_MODEL=gpt-4o-mini

# ── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/claimos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Kafka (Apache Kafka / Redpanda) ────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT       # Use SSL in production
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── Pinecone (Vector DB for Policy RAG) ────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=claimos-policy
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Neo4j (Fraud Network Graph) ────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ── AWS ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_QLDB_LEDGER_NAME=claimos-audit
AWS_DYNAMODB_AUDIT_TABLE=claimos-audit-dlq
AWS_S3_MODEL_BUCKET=claimos-ml-models
AWS_S3_DOCUMENTS_BUCKET=claimos-documents

# ── Azure Document Intelligence (OCR Primary) ──────────────
AZURE_FORM_RECOGNIZER_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=

# ── External Verification APIs ─────────────────────────────
UIDAI_API_BASE_URL=https://api.uidai.gov.in
UIDAI_API_KEY=
DIGILOCKER_API_BASE_URL=https://api.digitallocker.gov.in
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
SUREPASS_API_BASE_URL=https://kyc-api.surepass.io
SUREPASS_TOKEN=
NMC_REGISTRY_API_URL=https://registry.nmc.org.in/api
NHA_REGISTRY_API_URL=https://nha.gov.in/api
VAHAN_API_URL=https://vahan.nic.in/api

# ── Cohere (Reranking for Policy RAG) ──────────────────────
COHERE_API_KEY=

# ── Banking Settlement API ─────────────────────────────────
BANKING_API_BASE_URL=
BANKING_API_KEY=
BANKING_API_SECRET=

# ── JWT Auth (Internal API) ────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# ── IRDAI / Business Thresholds ────────────────────────────
FRAUD_AUTO_BLOCK_THRESHOLD=CRITICAL
AUTO_APPROVE_MAX_SUM_ASSURED=2500000
CONTESTABILITY_WINDOW_DAYS=730
SUICIDE_EXCLUSION_WINDOW_DAYS=365
AGENT_CONFIDENCE_MINIMUM=0.50
AGENT_CONFIDENCE_WARNING=0.65
UNCERTAINTY_SCORE_ESCALATION_THRESHOLD=0.65
OCR_CONFIDENCE_MINIMUM=0.65
MISSING_DOCUMENT_FOLLOWUP_SLA_DAYS=15
IRDAI_ACKNOWLEDGEMENT_SLA_HOURS=24
IRDAI_DECISION_SLA_DAYS=30
HUMAN_REVIEW_RESPONSE_SLA_HOURS=4
SECOND_REVIEWER_THRESHOLD=5000000

# ── App ────────────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8001

# Hugging Face Serverless API Keys (for parallel requests, round-robin rotated)
ENABLE_HUGGINGFACE=false
HF_API_KEY_1="hf_your_key_here_1"
HF_API_KEY_2="hf_your_key_here_2"
HF_API_KEY_3="hf_your_key_here_3"
HF_API_KEY_4="hf_your_key_here_4"
HF_API_KEY_5="hf_your_key_here_5"
HUGGINGFACE_MODEL="Qwen/Qwen2.5-72B-Instruct"

# Keep this false unless you explicitly want strict classifier checks even for fixed doc uploads
# such as DEATH_CERTIFICATE or CLAIMANT_STATEMENT_FORM.
STEP1_CLASSIFIER_FOR_FIXED_DOCS=false
# Upload validation hardening (defaults keep current behavior when false)
STRICT_UPLOAD_VALIDATION=false
STRICT_MIME_VALIDATION=false
MAX_UPLOAD_BYTES=15728640
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.pdf
# OCR reliability + throughput tuning
OCR_FALLBACK_ENABLED=true
RAPID_OCR_MAX_CONCURRENCY=2
PDF_PARALLEL_THRESHOLD_PAGES=1
PDF_PARALLEL_PAGE_WORKERS=4
# Nanonets OCR for claimant statement forms only.
# Actual secret can be NANO_OCR_APIKEY, NANONETS_API_KEY, or NANONETS_OCR_API_KEY.
NANO_OCR_APIKEY=
NANONETS_CLAIM_FORM_OCR_ENABLED=true
NANONETS_CLAIM_FORM_FALLBACK_LOCAL=true
NANONETS_OCR_ENDPOINT=https://extraction-api.nanonets.com/api/v1/extract/sync
NANONETS_OCR_OUTPUT_FORMAT=markdown
NANONETS_OCR_INCLUDE_METADATA=confidence_score
NANONETS_OCR_TIMEOUT_S=90
NANONETS_OCR_PROMPT_MODE=append
# LLM latency/retry guardrails
LLM_REQUEST_TIMEOUT_S=45
LLM_RETRY_COUNT=1
LLM_RETRY_BACKOFF_MS=400
LLM_INPUT_CHAR_LIMIT=30000
LLM_CHUNK_TOKEN_THRESHOLD=3500
LLM_MAX_CHUNKS_PER_DOC=10
LLM_MAX_CONCURRENT_CHUNKS_PER_DOC=2
LLM_CHUNK_OVERLAP_LINES=3
LLM_TIMEOUT_BASE_SECONDS=30
LLM_TIMEOUT_PER_1K_TOKENS=4
LLM_GROUNDING_CHECK_ENABLED=true
LLM_MAX_CONCURRENCY=4
OCR_WORKERS=4
LLM_WORKERS=4
VALIDATION_WORKERS=2
# Automatically run fraud + policy analysis after upload pipeline completion.
AUTO_FRAUD_ANALYSIS=true
# Local face verification for Stage 1. Runs separately from OCR/JSON extraction.
FACE_VERIFY_STAGE1_ENABLED=true
FACE_VERIFY_WORKERS=1
FACE_VERIFY_MODEL=Facenet512
FACE_VERIFY_DETECTOR_BACKEND=retinaface
FACE_VERIFY_DISTANCE_METRIC=cosine
FACE_VERIFY_ANTI_SPOOFING=true
FACE_VERIFY_MATCH_THRESHOLD=80
FACE_VERIFY_NO_MATCH_THRESHOLD=25
FACE_VERIFY_REVIEW_BAND_LOW=35
FACE_VERIFY_REVIEW_BAND_HIGH=65
FACE_VERIFY_MAX_PDF_PAGES=3
FACE_VERIFY_RENDER_DPI=180
FACE_VERIFY_MAX_IMAGE_SIDE=1600
FACE_VERIFY_FACE_CROP_PADDING_PX=24
FACE_VERIFY_FACE_CROP_PADDING_RATIO=0.18
FACE_VERIFY_RETURN_FACE_PREVIEWS=true
# Optional hedged extraction: HuggingFace + OpenAI in parallel, first valid JSON wins.
# Faster only when provider latency is stable; costs more and can overload multi-doc Step 1.
PARALLEL_JSON_EXTRACTION=false
# If HuggingFace extraction fails, retry once on OpenAI.
CLOUD_FALLBACK_TO_OPENAI=true
FALLBACK_OPENAI_MODEL=gpt-4o
